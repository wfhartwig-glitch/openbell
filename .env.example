# OpenBell — environment variable template
# Copy this file to .env and fill in your values.

# Gmail address you're sending from
GMAIL_ADDRESS=your_gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_16_char_app_password

# Recipient email
TO_EMAIL=your_email@gmail.com

# Financial Modeling Prep API key — primary market data source
# Free tier at https://financialmodelingprep.com
FMP_API_KEY=your_fmp_key

# NewsAPI key (optional) — free tier at https://newsapi.org/register
# Falls back to FMP stock news if not set
NEWS_API_KEY=your_newsapi_key_optional
