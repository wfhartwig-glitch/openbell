# OpenBell — environment variable template
# Copy this file to .env and fill in your values.

# Gmail address you're sending from
GMAIL_ADDRESS=you@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient email
TO_EMAIL=you@gmail.com

# Anthropic API key — get one at https://console.anthropic.com
# Used for Claude-generated commentary in all three email types
ANTHROPIC_API_KEY=sk-ant-...

# Financial Modeling Prep API key — primary market data source
# Free tier at https://financialmodelingprep.com (covers everything this system needs)
FMP_API_KEY=your_fmp_key_here

# NewsAPI key (optional) — free tier at https://newsapi.org/register
# Falls back to FMP stock news if not set
NEWS_API_KEY=your_newsapi_key_here
